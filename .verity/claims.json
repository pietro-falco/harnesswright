{
  "version": "0.1",
  "claims": [
    {
      "id": "license-exists",
      "type": "file_exists",
      "description": "LICENSE file exists at repo root",
      "path": "LICENSE"
    },
    {
      "id": "adr-001-committed",
      "type": "git_committed",
      "description": "ADR-001 is committed at HEAD",
      "path": "docs/adrs/0001-governance-first-harness-generator.md"
    },
    {
      "id": "adr-001-status-accepted",
      "type": "file_matches",
      "description": "ADR-001 declares Status: Accepted",
      "path": "docs/adrs/0001-governance-first-harness-generator.md",
      "match": {
        "kind": "substring",
        "value": "**Status:** Accepted"
      }
    },
    {
      "id": "package-json-name",
      "type": "file_matches",
      "description": "package.json declares the harnesswright package name",
      "path": "package.json",
      "match": {
        "kind": "substring",
        "value": "\"name\": \"harnesswright\""
      }
    },
    {
      "id": "pre-commit-hook-committed",
      "type": "git_committed",
      "description": "pre-commit hook is committed at HEAD",
      "path": ".githooks/pre-commit"
    },
    {
      "id": "ledger-committed",
      "type": "git_committed",
      "description": "slice ledger is committed at HEAD",
      "path": ".harness/ledger.md"
    },
    {
      "id": "pre-commit-hook-executable",
      "type": "command",
      "description": "pre-commit hook is committed with the executable bit set",
      "run": "sh -c 'git ls-files -s .githooks/pre-commit | grep -q ^100755'",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    },
    {
      "id": "cli-committed",
      "type": "git_committed",
      "description": "CLI entry point is committed at HEAD",
      "path": "src/cli.ts"
    },
    {
      "id": "build-succeeds",
      "type": "command",
      "description": "npm run build exits 0",
      "run": "npm run build",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    },
    {
      "id": "tests-pass",
      "type": "command",
      "description": "npm test exits 0",
      "run": "npm test",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    },
    {
      "id": "gate-unknown-slice-exits-2",
      "type": "command",
      "description": "gate exits 2 for an unknown slice id",
      "run": "sh -c 'node dist/cli.js gate NOPE; test $? -eq 2'",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    },
    {
      "id": "doctor-passes",
      "type": "command",
      "description": "doctor exits 0 against this repo",
      "run": "node dist/cli.js doctor",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    },
    {
      "id": "gate-reentrancy-guard",
      "type": "command",
      "description": "gate exits 2 when the re-entrancy guard env var is already set",
      "run": "sh -c 'HARNESSWRIGHT_GATE=1 node dist/cli.js gate; test $? -eq 2'",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    },
    {
      "id": "agents-md-committed",
      "type": "git_committed",
      "description": "AGENTS.md is committed at HEAD",
      "path": "AGENTS.md"
    },
    {
      "id": "skill-md-committed",
      "type": "git_committed",
      "description": "SKILL.md is committed at HEAD",
      "path": "SKILL.md"
    },
    {
      "id": "pack-includes-skill",
      "type": "command",
      "description": "npm pack --dry-run includes SKILL.md in the tarball",
      "run": "sh -c 'npm pack --dry-run 2>&1 | grep -q SKILL.md'",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    },
    {
      "id": "harness-config-committed",
      "type": "git_committed",
      "description": "self-hosted harness config is committed at HEAD",
      "path": ".harness/harness.json"
    },
    {
      "id": "gate-workflow-committed",
      "type": "git_committed",
      "description": "CI gate workflow is committed at HEAD",
      "path": ".github/workflows/gate.yml"
    },
    {
      "id": "security-md-committed",
      "type": "git_committed",
      "description": "security policy is committed at HEAD",
      "path": "SECURITY.md"
    },
    {
      "id": "changelog-committed",
      "type": "git_committed",
      "description": "changelog is committed at HEAD",
      "path": "CHANGELOG.md"
    },
    {
      "id": "version-is-0-1-0",
      "type": "file_matches",
      "description": "package.json declares version 0.1.0",
      "path": "package.json",
      "match": {
        "kind": "substring",
        "value": "\"version\": \"0.1.0\""
      }
    },
    {
      "id": "readme-built-with-itself",
      "type": "file_matches",
      "description": "README documents the built-with-itself incidents",
      "path": "README.md",
      "match": {
        "kind": "substring",
        "value": "## Built with itself"
      }
    },
    {
      "id": "demo-validator-committed",
      "type": "git_committed",
      "description": "OSINT demo validator is committed at HEAD",
      "path": "demo/osint/validate.py"
    },
    {
      "id": "demo-schema-passes",
      "type": "command",
      "description": "OSINT demo validator exits 0 from repo root",
      "run": "python3 demo/osint/validate.py",
      "timeoutMs": 60000,
      "expect": {
        "exitCode": 0
      }
    }
  ]
}
